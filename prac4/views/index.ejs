<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
        <title>Document</title>
    </head>

    <body>
        <div class="h-screen flex flex-col justify-center items-center bg-zinc-500">
            <h1 class="text-2xl font-bold mb-4 text-white">Create User</h1>
            <form action="/create" method="post" class="flex flex-col gap-2">
                <input type="text" name="name" placeholder="Name" class="border border-gray-300 rounded px-2 py-1 outline-none">
                <input type="email" name="email" placeholder="Email" class="border border-gray-300 rounded px-2 py-1 outline-none">
                <input type="text" name="img" placeholder="Image URL" class="border border-gray-300 rounded px-2 py-1 outline-none">
                <button type="submit" class="bg-blue-300 text-white px-4 py-2 rounded">Create</button>
            </form>

            <div class="read mt-4">
                <a href="/read" class="text-blue-700">Read Users</a>
            </div>
        </div>
    </body>

</html>